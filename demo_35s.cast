[5.393654, "o", "\u001b[7mpython3 -c \"\u001b[27m\r\n\r\u001b[7mfrom aelitium import enable_litellm\u001b[27m\r\n\r\u001b[7mimport litellm\u001b[27m\r\n\r\n\r\u001b[7menable_litellm(verbose=True)\u001b[27m\r\n\r\n\r\u001b[7mresponse = litellm.completion(\u001b[27m\r\n\r\u001b[7m    model='openai/gpt-4o',\u001b[27m\r\n\r\u001b[7m    messages=[{'role': 'user', 'content': 'Say hello in one sentence'}],\u001b[27m\r\n\r\u001b[7m)\u001b[27m\r\n\r\n\r\u001b[7mprint(response.choices[0].message.content)\u001b[27m\r\n\r\u001b[7m\"\u001b[27m"]
[6.93991, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\r\u001b[38;5;208m[B|catarina-aelitium@AELITIUM-DEV aelitium-v3]$\u001b[0m python3 -c \"\r\n\rfrom aelitium import enable_litellm\r\n\rimport litellm\r\n\r\n\renable_litellm(verbose=True)\r\n\r\n\rresponse = litellm.completion(\r\n\r    model='openai/gpt-4o',\r\n\r    messages=[{'role': 'user', 'content': 'Say hello in one sentence'}],\r\n\r)\r\n\r\n\rprint(response.choices[0].message.content)\r\n\r\"\r\n\u001b[?2004l\r"]
